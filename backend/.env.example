# Configurazione ambiente - CTI Feed RSS
# Copia questo file come .env e configura il motore AI desiderato

# ── Motore AI ──────────────────────────────────────────────────
# Scegli uno tra: ollama, gemini, openai
# Lascia vuoto per usare l'app senza AI (solo categorizzazione base)
AI_ENGINE=ollama

# Ollama — locale, gratuito (https://ollama.com)
# Installa Ollama, poi: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Google Gemini — gratuito con limiti (https://aistudio.google.com/apikey)
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI — a pagamento
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4o

DEBUG=true

# RSS
RSS_FETCH_INTERVAL_MINUTES=30
RSS_FETCH_TIMEOUT_SECONDS=15
MAX_ARTICLES_PER_FEED=50

# Cache
CACHE_TTL_HOURS=6

# Server
HOST=0.0.0.0
PORT=8000

# Server
HOST=0.0.0.0
PORT=8000
